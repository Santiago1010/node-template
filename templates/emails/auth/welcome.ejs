<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>

<body>
  <%- include('../layouts/header.ejs') %>

    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" border="0" class="email-container">
          <tr>
            <td class="email-content">
              <h1 class="heading-1">
                <%= welcomeGreeting %>
              </h1>

              <p class="text-body">
                <%= paragraph1 %>
              </p>

              <div class="alert alert-info">
                <p class="alert-title">
                  📌 <%= importantInformation %>
                </p>
                <p class="alert-text">
                  <%= paragraph2 %>
                </p>
              </div>

              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 30px 0;">
                <tr>
                  <td align="center">
                    <a href="<%= url %>" target="_blank" class="btn btn-primary">
                      <%= verifyMyEmail %>
                    </a>
                  </td>
                </tr>
              </table>

              <div class="divider-bold"></div>

              <h2 class="heading-2">
                <%= whatYouDo %>
              </h2>

              <div class="card">
                <h3 class="heading-3 color-primary">
                  ✨ <%= explorePanel.title %>
                </h3>
                <p class="text-body">
                  <%= explorePanel.paragraph %>
                </p>
              </div>

              <div class="card">
                <h3 class="heading-3 color-secondary">
                  🎯 <%= configProfile.title %>
                </h3>
                <p class="text-body">
                  <%= configProfile.paragraph %>
                </p>
              </div>

              <div class="alert alert-warning">
                <p class="alert-title">
                  ⏰ <%= reminder.title %>
                </p>
                <p class="alert-text">
                  <%= reminder.paragraph %>
                </p>
              </div>

              <div class="spacing-lg"></div>

              <p class="text-body">
                <%= questions %>
              </p>

              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 20px 0;">
                <tr>
                  <td align="center">
                    <a href="mailto:soporte@tuempresa.com" class="btn btn-outline">
                      <%= contactSupport %>
                    </a>
                  </td>
                </tr>
              </table>

              <div class="spacing-md"></div>
              <div
                style="background-color: #F8F9FA; padding: 20px; border-radius: 8px; border-left: 4px solid #6C757D;">
                <p class="text-small" style="margin: 0 0 10px 0; color: #6C757D;">
                  <strong>
                    <%= button %>
                  </strong>
                </p>
                <p class="text-small" style="margin: 0; color: #6C757D;">
                  <%= copyPaste %>
                </p>
                <p class="text-small" style="margin: 10px 0 0 0; word-break: break-all;">
                  <code style="background-color: #E9ECEF; padding: 5px 10px; border-radius: 4px; font-size: 12px;">
                    <%= url %>
                  </code>
                </p>
              </div>

              <div class="spacing-lg"></div>
              <p class="text-body">
                <%= thanks %>,
                  <br>
                  <span class="text-bold color-primary">Company Inc.</span>
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>

    <%- include('../layouts/footer.ejs') %>
</body>

</html>
