<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>

<body>
  <%- include('../layouts/header.ejs') %>

    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" border="0" class="email-container">
          <!-- Contenido principal -->
          <tr>
            <td class="email-content">

              <!-- Título principal con icono de éxito -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="padding-bottom: 20px;">
                    <div
                      style="width: 80px; height: 80px; background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3);">
                      <span style="font-size: 40px; color: #FFFFFF;">✓</span>
                    </div>
                  </td>
                </tr>
              </table>

              <h1 class="heading-1" style="text-align: center; color: #22C55E;">
                <%= passwordChanged %>
              </h1>

              <!-- Saludo -->
              <p class="text-body">
                <%= greeting %>
              </p>

              <!-- Párrafo 1 -->
              <p class="text-body">
                <%= paragraph1 %>
              </p>

              <!-- Espaciado -->
              <div class="spacing-md"></div>

              <!-- Detalles del cambio -->
              <div class="card-highlight"
                style="background: linear-gradient(135deg, #1A1D23 0%, #2C3038 100%); color: #FFFFFF; border: none; border-radius: 8px; padding: 24px; margin: 20px 0;">
                <h3 class="heading-3" style="color: #D4AF37; margin-top: 0;">
                  📋 <%= changeDetails.title %>
                </h3>

                <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top: 16px;">
                  <tr>
                    <td style="padding: 10px 0; border-bottom: 1px solid rgba(212, 175, 55, 0.2);">
                      <p style="margin: 0; font-size: 14px; color: #9CA3AF;">
                        <strong style="color: #D4AF37;">
                          <%= changeDetails.date %>:
                        </strong>
                      </p>
                      <p style="margin: 4px 0 0 0; font-size: 15px; color: #FFFFFF;">
                        <%= changeDate %>
                      </p>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding: 10px 0; border-bottom: 1px solid rgba(212, 175, 55, 0.2);">
                      <p style="margin: 0; font-size: 14px; color: #9CA3AF;">
                        <strong style="color: #D4AF37;">
                          <%= changeDetails.browser %>:
                        </strong>
                      </p>
                      <p style="margin: 4px 0 0 0; font-size: 15px; color: #FFFFFF;">
                        <%= browser %>
                      </p>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding: 10px 0; border-bottom: 1px solid rgba(212, 175, 55, 0.2);">
                      <p style="margin: 0; font-size: 14px; color: #9CA3AF;">
                        <strong style="color: #D4AF37;">
                          <%= changeDetails.location %>:
                        </strong>
                      </p>
                      <p style="margin: 4px 0 0 0; font-size: 15px; color: #FFFFFF;">
                        <%= location %>
                      </p>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding: 10px 0;">
                      <p style="margin: 0; font-size: 14px; color: #9CA3AF;">
                        <strong style="color: #D4AF37;">
                          <%= changeDetails.ip %>:
                        </strong>
                      </p>
                      <p style="margin: 4px 0 0 0; font-size: 15px; color: #FFFFFF;">
                        <%= ipAddress %>
                      </p>
                    </td>
                  </tr>
                </table>
              </div>

              <!-- Espaciado -->
              <div class="spacing-sm"></div>

              <!-- Confirmación -->
              <div class="alert alert-success">
                <p class="alert-text" style="margin: 0;">
                  <%= paragraph2 %>
                </p>
              </div>

              <!-- Divisor -->
              <div class="divider"></div>

              <!-- Si no fuiste tú -->
              <div class="alert alert-error">
                <p class="alert-title">
                  🚨 <%= notYou.title %>
                </p>
                <p class="alert-text">
                  <%= notYou.paragraph %>
                </p>
              </div>

              <!-- Acciones inmediatas -->
              <div class="card" style="background-color: #FEF2F2; border: 1px solid #FEE2E2;">
                <h3 class="heading-3" style="color: #DC143C; margin-top: 0;">
                  ⚡ <%= immediateActions.title %>
                </h3>

                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="padding: 8px 0;">
                      <p class="text-body" style="margin: 0; color: #991B1B;">
                        <span
                          style="display: inline-block; width: 24px; height: 24px; background-color: #DC143C; color: #FFFFFF; border-radius: 50%; text-align: center; line-height: 24px; font-weight: 600; font-size: 12px; margin-right: 8px;">1</span>
                        <%= immediateActions.action1 %>
                      </p>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding: 8px 0;">
                      <p class="text-body" style="margin: 0; color: #991B1B;">
                        <span
                          style="display: inline-block; width: 24px; height: 24px; background-color: #DC143C; color: #FFFFFF; border-radius: 50%; text-align: center; line-height: 24px; font-weight: 600; font-size: 12px; margin-right: 8px;">2</span>
                        <%= immediateActions.action2 %>
                      </p>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding: 8px 0;">
                      <p class="text-body" style="margin: 0; color: #991B1B;">
                        <span
                          style="display: inline-block; width: 24px; height: 24px; background-color: #DC143C; color: #FFFFFF; border-radius: 50%; text-align: center; line-height: 24px; font-weight: 600; font-size: 12px; margin-right: 8px;">3</span>
                        <%= immediateActions.action3 %>
                      </p>
                    </td>
                  </tr>
                </table>
              </div>

              <!-- Botones de acción -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 30px 0;">
                <tr>
                  <td align="center">
                    <table cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding: 0 10px;">
                          <a href="<%= securityUrl %>" class="btn btn-primary"
                            style="display: inline-block; padding: 14px 28px; background-color: #DC143C; color: #FFFFFF; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 15px;">
                            <%= reviewSecurity %>
                          </a>
                        </td>
                        <td style="padding: 0 10px;">
                          <a href="<%= supportUrl %>" class="btn btn-outline"
                            style="display: inline-block; padding: 12px 26px; background-color: transparent; border: 2px solid #DC143C; color: #DC143C; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 15px;">
                            <%= contactSupport %>
                          </a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Divisor -->
              <div class="divider"></div>

              <!-- Recomendaciones de seguridad -->
              <div class="card">
                <h3 class="heading-3" style="color: #1A1D23; margin-top: 0;">
                  💡 <%= securityRecommendations.title %>
                </h3>

                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td class="list-item">
                      <p class="text-body" style="margin: 0;">
                        <span style="color: #D4AF37; font-weight: 600;">★</span>
                        <%= securityRecommendations.rec1 %>
                      </p>
                    </td>
                  </tr>
                  <tr>
                    <td class="list-item">
                      <p class="text-body" style="margin: 0;">
                        <span style="color: #D4AF37; font-weight: 600;">★</span>
                        <%= securityRecommendations.rec2 %>
                      </p>
                    </td>
                  </tr>
                  <tr>
                    <td class="list-item">
                      <p class="text-body" style="margin: 0;">
                        <span style="color: #D4AF37; font-weight: 600;">★</span>
                        <%= securityRecommendations.rec3 %>
                      </p>
                    </td>
                  </tr>
                </table>
              </div>

              <!-- Espaciado -->
              <div class="spacing-lg"></div>

              <!-- Mensaje de despedida -->
              <p class="text-body" style="text-align: center; color: #6B7280;">
                <%= thanks %>
              </p>

            </td>
          </tr>
        </table>
      </td>
    </tr>

    <%- include('../layouts/footer.ejs') %>
</body>

</html>
