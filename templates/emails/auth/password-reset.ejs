<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>

<body>
  <%- include('../layouts/header.ejs') %>

    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" border="0" class="email-container">
          <!-- Contenido principal -->
          <tr>
            <td class="email-content">

              <!-- Título principal -->
              <h1 class="heading-1" style="color: #DC143C;">
                🔐 <%= passwordReset %>
              </h1>

              <!-- Saludo -->
              <p class="text-body">
                <%= greeting %>
              </p>

              <!-- Párrafo 1 -->
              <p class="text-body">
                <%= paragraph1 %>
              </p>

              <!-- Párrafo 2 -->
              <p class="text-body">
                <%= paragraph2 %>
              </p>

              <!-- Espaciado -->
              <div class="spacing-md"></div>

              <!-- Botón principal -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="padding: 20px 0;">
                    <a href="<%= resetUrl %>" class="btn btn-primary"
                      style="display: inline-block; padding: 16px 40px; background-color: #DC143C; color: #FFFFFF; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 16px; box-shadow: 0 4px 6px rgba(220, 20, 60, 0.3);">
                      <%= resetPassword %>
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Espaciado -->
              <div class="spacing-sm"></div>

              <!-- Alerta de expiración -->
              <div class="alert alert-warning">
                <p class="alert-title">
                  ⏰ <%= expirationNotice.title %>
                </p>
                <p class="alert-text">
                  <%= expirationNotice.paragraph %>
                </p>
              </div>

              <!-- Divisor -->
              <div class="divider"></div>

              <!-- Tips de seguridad -->
              <div class="card">
                <h3 class="heading-3" style="color: #1A1D23; margin-top: 0;">
                  🛡️ <%= securityTips.title %>
                </h3>

                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td class="list-item">
                      <p class="text-body" style="margin: 0;">
                        <span style="color: #DC143C; font-weight: 600;">✓</span>
                        <%= securityTips.tip1 %>
                      </p>
                    </td>
                  </tr>
                  <tr>
                    <td class="list-item">
                      <p class="text-body" style="margin: 0;">
                        <span style="color: #DC143C; font-weight: 600;">✓</span>
                        <%= securityTips.tip2 %>
                      </p>
                    </td>
                  </tr>
                  <tr>
                    <td class="list-item">
                      <p class="text-body" style="margin: 0;">
                        <span style="color: #DC143C; font-weight: 600;">✓</span>
                        <%= securityTips.tip3 %>
                      </p>
                    </td>
                  </tr>
                </table>
              </div>

              <!-- Divisor -->
              <div class="divider"></div>

              <!-- Si no lo solicitaste -->
              <div class="alert alert-error">
                <p class="alert-title">
                  ⚠️ <%= notRequested.title %>
                </p>
                <p class="alert-text">
                  <%= notRequested.paragraph %>
                </p>
              </div>

              <!-- Espaciado -->
              <div class="spacing-sm"></div>

              <!-- Contactar soporte -->
              <p class="text-body" style="text-align: center;">
                <%= contactSupport %>
              </p>

              <!-- Divisor decorativo -->
              <div class="divider-bold"></div>

              <!-- Alternativa de enlace -->
              <div style="background-color: #F9FAFB; padding: 20px; border-radius: 8px; border: 1px dashed #E5E7EB;">
                <p class="text-small" style="margin: 0 0 12px 0; font-weight: 600; color: #6B7280;">
                  <%= alternative.button %>
                </p>
                <p class="text-small" style="margin: 0 0 8px 0; color: #6B7280;">
                  <%= alternative.copyPaste %>
                </p>
                <p
                  style="margin: 0; padding: 12px; background-color: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 6px; font-size: 13px; color: #2C3038; word-break: break-all; font-family: 'Courier New', monospace;">
                  <%= resetUrl %>
                </p>
              </div>

              <!-- Espaciado -->
              <div class="spacing-lg"></div>

              <!-- Mensaje de despedida -->
              <p class="text-body" style="text-align: center; color: #6B7280;">
                <%= thanks %>
              </p>

            </td>
          </tr>
        </table>
      </td>
    </tr>

    <%- include('../layouts/footer.ejs') %>
</body>

</html>
