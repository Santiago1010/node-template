<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>

<body>
  <%- include('../layouts/header.ejs') %>

    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" border="0" class="email-container">
          <tr>
            <td class="email-content">
              <h1 class="heading-1">
                <%= securityAlert %>
              </h1>

              <div class="alert alert-warning">
                <p class="alert-title">
                  🔐 <%= unknownDeviceDetected %>
                </p>
                <p class="alert-text">
                  <%= paragraph1 %>
                </p>
              </div>

              <p class="text-body">
                <%= paragraph2 %>
              </p>

              <div class="card">
                <h3 class="heading-3 color-dark">
                  📱 <%= deviceInfo.title %>
                </h3>
                <table width="100%" cellpadding="8" cellspacing="0" border="0">
                  <tr class="list-item">
                    <td class="text-small text-bold" width="40%">
                      <%= deviceInfo.device %>:
                    </td>
                    <td class="text-small">
                      <%= device %>
                    </td>
                  </tr>
                  <tr class="list-item">
                    <td class="text-small text-bold">
                      <%= deviceInfo.browser %>:
                    </td>
                    <td class="text-small">
                      <%= browser %>
                    </td>
                  </tr>
                  <tr class="list-item">
                    <td class="text-small text-bold">
                      <%= deviceInfo.location %>:
                    </td>
                    <td class="text-small">
                      <%= location %>
                    </td>
                  </tr>
                  <tr class="list-item">
                    <td class="text-small text-bold">
                      <%= deviceInfo.ip %>:
                    </td>
                    <td class="text-small">
                      <%= ipAddress %>
                    </td>
                  </tr>
                  <tr class="list-item">
                    <td class="text-small text-bold">
                      <%= deviceInfo.date %>:
                    </td>
                    <td class="text-small">
                      <%= loginDate %>
                    </td>
                  </tr>
                </table>
              </div>

              <div class="divider-bold"></div>

              <h2 class="heading-2">
                <%= safeModeActive %>
              </h2>

              <p class="text-body">
                <%= paragraph3 %>
              </p>

              <div class="card-highlight"
                style="background: linear-gradient(135deg, #1A1D23 0%, #2C3038 100%); color: #FFFFFF; border: none; border-radius: 8px; padding: 20px; margin: 20px 0;">
                <h3 class="heading-3" style="color: #D4AF37; margin: 0 0 12px 0;">
                  🛡️ <%= safeModeFeatures.title %>
                </h3>
                <ul style="margin: 0; padding-left: 20px; color: #E5E7EB;">
                  <li style="margin-bottom: 8px; font-size: 14px; line-height: 1.6;">
                    <%= safeModeFeatures.feature1 %>
                  </li>
                  <li style="margin-bottom: 8px; font-size: 14px; line-height: 1.6;">
                    <%= safeModeFeatures.feature2 %>
                  </li>
                  <li style="margin-bottom: 8px; font-size: 14px; line-height: 1.6;">
                    <%= safeModeFeatures.feature3 %>
                  </li>
                  <li style="font-size: 14px; line-height: 1.6;">
                    <%= safeModeFeatures.feature4 %>
                  </li>
                </ul>
              </div>

              <div class="spacing-md"></div>

              <p class="text-body text-bold">
                <%= confirmInstructions %>
              </p>

              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 30px 0;">
                <tr>
                  <td align="center">
                    <a href="<%= confirmUrl %>" target="_blank" class="btn btn-primary">
                      <%= confirmDevice %>
                    </a>
                  </td>
                </tr>
              </table>

              <div class="alert alert-error">
                <p class="alert-title">
                  ⚠️ <%= notYou.title %>
                </p>
                <p class="alert-text">
                  <%= notYou.paragraph %>
                </p>
              </div>

              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 20px 0;">
                <tr>
                  <td align="center">
                    <a href="<%= securityUrl %>" target="_blank" class="btn btn-outline">
                      <%= reviewSecurity %>
                    </a>
                  </td>
                </tr>
              </table>

              <div class="spacing-md"></div>
              <div
                style="background-color: #F8F9FA; padding: 20px; border-radius: 8px; border-left: 4px solid #6C757D;">
                <p class="text-small" style="margin: 0 0 10px 0; color: #6C757D;">
                  <strong>
                    <%= alternative.button %>
                  </strong>
                </p>
                <p class="text-small" style="margin: 0; color: #6C757D;">
                  <%= alternative.copyPaste %>
                </p>
                <p class="text-small" style="margin: 10px 0 0 0; word-break: break-all;">
                  <code style="background-color: #E9ECEF; padding: 5px 10px; border-radius: 4px; font-size: 12px;">
                    <%= confirmUrl %>
                  </code>
                </p>
              </div>

              <div class="spacing-lg"></div>
              <p class="text-body">
                <%= thanks %>,
                  <br>
                  <span class="text-bold color-primary">Company Inc.</span>
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>

    <%- include('../layouts/footer.ejs') %>
</body>

</html>
