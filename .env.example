# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
NODE_ENV=local
PORT=8080
BASE_URL=http://localhost:8080
PROJECT_NAME=node-template

# Internationalization
DEFAULT_TIME_ZONE_NAME=America/Bogota
DEFAULT_TIME_ZONE_UTC=-05:00
DEFAULT_LANG=es

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_DIALECT=mysql
DB_SSL=false

# Read Replica
DB_READ_HOST=localhost
DB_READ_PORT=3306

# =============================================================================
# CACHE & SESSION STORAGE
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_HOST_LOCAL=localhost

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
DEFAULT_PASSWORD_LENGTH=8

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRATION_TIME=900000
JWT_REFRESH_TOKEN_EXPIRATION_TIME=604800000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# CLOUD STORAGE & LOCALSTACK
# =============================================================================
AWS_REGION=us-east-1
AWS_S3_BUCKET=localstack-bucket
AWS_ENDPOINT_URL=http://localstack:4566
GOOGLE_CLOUD_PROJECT_ID=your_gcp_project_id
GOOGLE_CLOUD_STORAGE_BUCKET=your_gcs_bucket_name
AZURE_STORAGE_CONTAINER=your_container_name

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================
DEBUG=true
LOG_LEVEL=debug
FAKER_LOCALE=es
FAKER_SEED=12345

# =============================================================================
# CORS & SECURITY HEADERS
# =============================================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self' 'unsafe-inline'
CSP_STYLE_SRC='self' 'unsafe-inline'

# App config
BOLA_STRICT_MODE=true
CSRF_ENABLED=true
CSRF_STRICT_MODE=true

MAX_FILE_SIZE_MB=10
MAX_FILES_PER_REQUEST=5

SECURITY_AUDIT_ENABLED=true
ANOMALY_DETECTION_ENABLED=true

# =============================================================================
# SMTP / EMAIL CONFIGURATION
# =============================================================================
# Name of the SMTP provider or service (e.g. Mailhog, Gmail, SES, etc.)
SMTP_SERVICE=MailHog

# SMTP Host — points to the Mailhog container locally
SMTP_HOST=localhost
# SMTP Port — 1025 for Mailhog, 587 or 465 for real servers
SMTP_PORT=1025

# Whether the server uses TLS/SSL (false for Mailhog)
SMTP_SECURE=false

# Default "from" address for outgoing emails
MAIL_DEFAULT_FROM="no-reply@node-template.local"

# Support or general contact address
MAIL_SUPPORT_ADDRESS="support@node-template.local"

# Advanced configuration (Optional TLS)
SMTP_TLS_REJECT_UNAUTHORIZED=false

# =============================================================================
# VAULT CONFIGURATION
# =============================================================================
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-only-token
