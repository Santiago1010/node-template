# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================

# Application Environment
# Options: 'production', 'development', 'test', 'local', 'staging'
NODE_ENV=development

# Server Configuration
PORT=8080
BASE_URL=http://localhost:${PORT}
API_VERSION=v1

# Internationalization
DEFAULT_TIME_ZONE='America/Bogota'
DEFAULT_LANG=en
SUPPORTED_LANGUAGES=en,es,fr,de,pt

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Primary Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_DIALECT=mysql
DB_SSL=false
DB_POOL_MIN=0
DB_POOL_MAX=10
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Database URLs (Alternative connection method)
DATABASE_URL=mysql://username:password@localhost:3306/database_name

# Read Replica Database (Optional for scaling)
DB_READ_HOST=localhost
DB_READ_PORT=3306
DB_READ_USERNAME=readonly_user
DB_READ_PASSWORD=readonly_password

# =============================================================================
# CACHE & SESSION STORAGE
# =============================================================================

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_URL=redis://localhost:6379

# Memcached (Alternative caching)
MEMCACHED_HOST=localhost
MEMCACHED_PORT=11211

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# General Security
SECURE_PASSWORD=your_secure_password_here
DEFAULT_PASSWORD_LENGTH=8
COOKIE_SECRET='your_cookie_secret_here'
SESSION_SECRET='your_session_secret_here'

# JWT Configuration
JWT_SESSION_SECRET='your_jwt_session_secret_here'
JWT_REFRESH_SESSION_SECRET='your_jwt_refresh_secret_here'
JWT_SESSION_TOKEN_EXPIRATION_TIME=900000
JWT_SESSION_REFRESH_TOKEN_EXPIRATION_TIME=604800000
JWT_SESSION_SUBJECT='main_access_token'
JWT_REFRESH_SUBJECT='main_refresh_token'
JWT_ALGORITHM=HS256

# OAuth Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Microsoft/Azure AD
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=your_tenant_id

# Apple Sign In
APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY=your_apple_private_key

# Email Confirmation
CONFIRM_EMAIL_SIGNATURE=your_email_confirm_signature
CONFIRM_EMAIL_EXPIRATION=3600
MAIN_CONFIRMATION='http://localhost:3000/confirm-account?token='

# Password Reset
FORGOT_PASSWORD_SECRET='your_forgot_password_secret_here'
PASSWORD_RESET_EXPIRATION=3600
PASSWORD_RESET_URL='http://localhost:3000/reset-password?token='

# Encryption (AES)
USER_PASSWORD_KEY='your_32_char_encryption_key_here'
USER_PASSWORD_IV='your_16_char_iv_here'
HYBRID_KEY='your_32_char_hybrid_key_here'
HYBRID_IV='your_16_char_hybrid_iv_here'

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# EMAIL SERVICES
# =============================================================================

# SMTP Configuration
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@domain.com
EMAIL_PASSWORD=your_email_password

# Email Templates
DEFAULT_FROM='noreply@yourdomain.com'
DEFAULT_TO='admin@yourdomain.com'
EMAIL_HEADER='https://your-domain.com/path/to/header-image.jpg'
EMAIL_FOOTER='https://your-domain.com/path/to/footer-image.jpg'

# Email Service Providers
SENDGRID_API_KEY=your_sendgrid_api_key
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=your_mailgun_domain
MAILCHIMP_API_KEY=your_mailchimp_api_key
MAILCHIMP_LIST_ID=your_mailchimp_list_id

# AWS SES
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY=your_aws_ses_access_key
AWS_SES_SECRET_KEY=your_aws_ses_secret_key

# =============================================================================
# PAYMENT GATEWAYS
# =============================================================================

# Stripe
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CURRENCY=usd

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# Square
SQUARE_APPLICATION_ID=your_square_app_id
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_key
SQUARE_ENVIRONMENT=sandbox

# Mercado Pago (Latin America)
MERCADO_PAGO_ACCESS_TOKEN=your_mercado_pago_token
MERCADO_PAGO_PUBLIC_KEY=your_mercado_pago_public_key

# PayU (Latin America)
PAYU_API_KEY=your_payu_api_key
PAYU_MERCHANT_ID=your_payu_merchant_id
PAYU_ACCOUNT_ID=your_payu_account_id
PAYU_TEST_MODE=true

# Razorpay (India)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# =============================================================================
# CLOUD STORAGE & CDN
# =============================================================================

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_s3_bucket_name
AWS_CLOUDFRONT_DOMAIN=your_cloudfront_domain

# Google Cloud Storage
GOOGLE_CLOUD_PROJECT_ID=your_gcp_project_id
GOOGLE_CLOUD_KEY_FILE=path/to/service-account-key.json
GOOGLE_CLOUD_STORAGE_BUCKET=your_gcs_bucket_name

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT=your_azure_storage_account
AZURE_STORAGE_KEY=your_azure_storage_key
AZURE_STORAGE_CONTAINER=your_container_name

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# =============================================================================
# AI & MACHINE LEARNING SERVICES
# =============================================================================

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_ORGANIZATION=your_openai_organization_id

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Hugging Face
HUGGING_FACE_API_KEY=your_hugging_face_token

# Cohere
COHERE_API_KEY=your_cohere_api_key

# =============================================================================
# COMMUNICATION SERVICES
# =============================================================================

# Twilio (SMS, Voice, Video)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_whatsapp_webhook_token

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_WEBHOOK_URL=your_slack_webhook_url

# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=your_telegram_webhook_url

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================

# Google Analytics
GOOGLE_ANALYTICS_TRACKING_ID=GA_MEASUREMENT_ID
GOOGLE_ANALYTICS_API_SECRET=your_ga_api_secret

# Mixpanel
MIXPANEL_TOKEN=your_mixpanel_token

# Segment
SEGMENT_WRITE_KEY=your_segment_write_key

# PostHog
POSTHOG_API_KEY=your_posthog_api_key
POSTHOG_HOST=https://app.posthog.com

# New Relic
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key
NEW_RELIC_APP_NAME=your_app_name

# Datadog
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key

# Sentry (Error Tracking)
SENTRY_DSN=your_sentry_dsn
SENTRY_ENVIRONMENT=development

# =============================================================================
# SEARCH SERVICES
# =============================================================================

# Elasticsearch
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_elasticsearch_password

# Algolia
ALGOLIA_APPLICATION_ID=your_algolia_app_id
ALGOLIA_API_KEY=your_algolia_api_key
ALGOLIA_SEARCH_KEY=your_algolia_search_key

# =============================================================================
# BACKGROUND JOBS & QUEUES
# =============================================================================

# Bull/BullMQ (Redis-based)
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379
BULL_REDIS_PASSWORD=your_bull_redis_password

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# AWS SQS
AWS_SQS_QUEUE_URL=your_sqs_queue_url
AWS_SQS_REGION=us-east-1

# =============================================================================
# EXTERNAL APIs & SERVICES
# =============================================================================

# Maps & Location
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# Weather
OPENWEATHER_API_KEY=your_openweather_api_key

# Currency Exchange
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key

# Social Media APIs
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token

YOUTUBE_API_KEY=your_youtube_api_key

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================

# Debug Mode
DEBUG=false
LOG_LEVEL=info

# Testing
TEST_DATABASE_URL=mysql://test_user:test_pass@localhost:3306/test_db

# Faker (for seed data)
FAKER_LOCALE=en_US
FAKER_SEED=12345

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Application Features
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR_AUTH=false
ENABLE_SOCIAL_LOGIN=true
ENABLE_API_RATE_LIMITING=true
ENABLE_MAINTENANCE_MODE=false

# Third-party Feature Flags
LAUNCHDARKLY_SDK_KEY=your_launchdarkly_key
OPTIMIZELY_SDK_KEY=your_optimizely_key

# =============================================================================
# CORS & SECURITY HEADERS
# =============================================================================

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Content Security Policy
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self' 'unsafe-inline'
CSP_STYLE_SRC='self' 'unsafe-inline'
