# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
# Node.js environment configuration
# Documentation: https://nodejs.org/api/process.html#process_process_env
# Best practices: https://12factor.net/config

# Application Environment
# Options: 'production', 'development', 'test', 'local', 'staging'
# Reference: https://expressjs.com/en/advanced/best-practice-performance.html#set-node_env-to-production
NODE_ENV=local

# Server Configuration
# Express.js server settings: https://expressjs.com/en/4x/api.html#app.listen
PORT=8080
BASE_URL=http://localhost:8080

# Internationalization
# ICU time zones: https://unicode-org.github.io/icu/userguide/datetime/#time-zone-metadata
DEFAULT_TIME_ZONE_NAME=America/Bogota
DEFAULT_TIME_ZONE_UTC=-05:00
# ISO language codes: https://en.wikipedia.org/wiki/List_of_ISO_639-1_codes
DEFAULT_LANG=es

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Sequelize ORM configuration: https://sequelize.org/docs/v6/getting-started/
# MySQL configuration: https://dev.mysql.com/doc/

# Primary Database (MySQL)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=db_template
DB_USER=admin
DB_PASSWORD=admin
DB_DIALECT=mysql
DB_SSL=false
# Connection pool settings: https://sequelize.org/docs/v6/getting-started/#connecting-to-a-database
DB_POOL_MIN=0
DB_POOL_MAX=10
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Database URLs (Alternative connection method — ready for Docker)
# Connection URI format: https://www.connectionstrings.com/
DATABASE_URL=mysql://admin:admin@mysql:3306/db_template

# Read Replica Database (optional)
DB_READ_HOST=mysql
DB_READ_PORT=3306
DB_READ_USERNAME=readonly_user
DB_READ_PASSWORD=readonly_password

# =============================================================================
# CACHE & SESSION STORAGE
# =============================================================================
# Redis documentation: https://redis.io/documentation
# Node Redis: https://github.com/redis/node-redis

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# Local fallback (useful if you run the app outside of Docker)
REDIS_HOST_LOCAL=localhost
REDIS_URL_LOCAL=redis://localhost:6379/0

# Memcached (Alternative caching)
# Memcached: https://github.com/3rd-Eden/memcached
MEMCACHED_HOST=localhost
MEMCACHED_PORT=11211

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# OWASP Security Best Practices: https://cheatsheetseries.owasp.org/cheatsheets/NodeJS_Security_Cheat_Sheet.html

# General Security
SECURE_PASSWORD=your_secure_password_here
DEFAULT_PASSWORD_LENGTH=8
COOKIE_SECRET=your_cookie_secret_here
SESSION_SECRET=your_session_secret_here

# JWT Configuration
# JSON Web Tokens: https://github.com/auth0/node-jsonwebtoken
JWT_SESSION_SECRET=your_jwt_session_secret_here
JWT_REFRESH_SESSION_SECRET=your_jwt_refresh_secret_here
JWT_SESSION_TOKEN_EXPIRATION_TIME=900000
JWT_SESSION_REFRESH_TOKEN_EXPIRATION_TIME=604800000
JWT_SESSION_SUBJECT=main_access_token
JWT_REFRESH_SUBJECT=main_refresh_token
JWT_ALGORITHM=HS256

# OAuth Providers
# Passport.js authentication: http://www.passportjs.org/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=your_tenant_id

APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY=your_apple_private_key

# Email Confirmation
CONFIRM_EMAIL_SIGNATURE=your_email_confirm_signature
CONFIRM_EMAIL_EXPIRATION=3600
MAIN_CONFIRMATION=http://localhost:3000/confirm-account?token=

# Password Reset
FORGOT_PASSWORD_SECRET=your_forgot_password_secret_here
PASSWORD_RESET_EXPIRATION=3600
PASSWORD_RESET_URL=http://localhost:3000/reset-password?token=

# Encryption (AES)
# Node.js Crypto module: https://nodejs.org/api/crypto.html
USER_PASSWORD_KEY=your_32_char_encryption_key_here
USER_PASSWORD_IV=your_16_char_iv_here
HYBRID_KEY=your_32_char_hybrid_key_here
HYBRID_IV=your_16_char_hybrid_iv_here

# Rate Limiting
# Express rate limit: https://github.com/nfriedly/express-rate-limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# EMAIL SERVICES
# =============================================================================
# Nodemailer: https://nodemailer.com/

# SMTP Configuration
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=

# Email Templates
DEFAULT_FROM=noreply@localhost
DEFAULT_TO=admin@localhost
EMAIL_HEADER=
EMAIL_FOOTER=

# Email Service Providers
SENDGRID_API_KEY=your_sendgrid_api_key
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=your_mailgun_domain
MAILCHIMP_API_KEY=your_mailchimp_api_key
MAILCHIMP_LIST_ID=your_mailchimp_list_id

# AWS SES
# AWS SDK: https://docs.aws.amazon.com/AWSJavaScriptSDK/latest/AWS/SES.html
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY=your_aws_ses_access_key
AWS_SES_SECRET_KEY=your_aws_ses_secret_key

# =============================================================================
# CLOUD STORAGE & LOCALSTACK
# =============================================================================
# AWS SDK S3: https://docs.aws.amazon.com/AWSJavaScriptSDK/latest/AWS/S3.html

# AWS S3 (for LocalStack, you can point to the local endpoint)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_S3_BUCKET=localstack-bucket
AWS_CLOUDFRONT_DOMAIN=
AWS_ENDPOINT_URL=http://localstack:4566

# Google Cloud Storage
# @google-cloud/storage: https://googleapis.dev/nodejs/storage/latest/
GOOGLE_CLOUD_PROJECT_ID=your_gcp_project_id
GOOGLE_CLOUD_KEY_FILE=path/to/service-account-key.json
GOOGLE_CLOUD_STORAGE_BUCKET=your_gcs_bucket_name

# Azure Blob Storage
# @azure/storage-blob: https://docs.microsoft.com/en-us/javascript/api/overview/azure/storage-blob-readme
AZURE_STORAGE_ACCOUNT=your_azure_storage_account
AZURE_STORAGE_KEY=your_azure_storage_key
AZURE_STORAGE_CONTAINER=your_container_name

# Cloudinary
# cloudinary npm package: https://github.com/cloudinary/cloudinary_npm
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# =============================================================================
# AI & MACHINE LEARNING SERVICES
# =============================================================================
OPENAI_API_KEY=your_openai_api_key
OPENAI_ORGANIZATION=your_openai_organization_id
GEMINI_API_KEY=your_gemini_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_API_VERSION=2024-02-15-preview
HUGGING_FACE_API_KEY=your_hugging_face_token
COHERE_API_KEY=your_cohere_api_key

# =============================================================================
# COMMUNICATION SERVICES
# =============================================================================
# Twilio Node.js: https://www.twilio.com/docs/libraries/node
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# WhatsApp Business API
# https://developers.facebook.com/docs/whatsapp/cloud-api/
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_whatsapp_webhook_token

# Slack API: https://api.slack.com/
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_WEBHOOK_URL=your_slack_webhook_url

# Discord: https://discord.com/developers/docs
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Telegram Bot API: https://core.telegram.org/bots/api
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=your_telegram_webhook_url

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================
# Google Analytics: https://developers.google.com/analytics
GOOGLE_ANALYTICS_TRACKING_ID=GA_MEASUREMENT_ID
GOOGLE_ANALYTICS_API_SECRET=your_ga_api_secret
MIXPANEL_TOKEN=your_mixpanel_token
SEGMENT_WRITE_KEY=your_segment_write_key
POSTHOG_API_KEY=your_posthog_api_key
POSTHOG_HOST=https://app.posthog.com
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key
NEW_RELIC_APP_NAME=your_app_name
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key
SENTRY_DSN=your_sentry_dsn
SENTRY_ENVIRONMENT=development

# =============================================================================
# BACKGROUND JOBS & QUEUES
# =============================================================================
# Bull Queue: https://github.com/OptimalBits/bull
BULL_REDIS_HOST=redis
BULL_REDIS_PORT=6379
BULL_REDIS_PASSWORD=

# RabbitMQ: https://www.rabbitmq.com/documentation.html
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# AWS SQS: https://docs.aws.amazon.com/AWSSimpleQueueService/latest/APIReference/Welcome.html
AWS_SQS_QUEUE_URL=your_sqs_queue_url
AWS_SQS_REGION=us-east-1

# =============================================================================
# EXTERNAL APIs & SERVICES
# =============================================================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token
OPENWEATHER_API_KEY=your_openweather_api_key
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
YOUTUBE_API_KEY=your_youtube_api_key

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================
DEBUG=true
LOG_LEVEL=debug
TEST_DATABASE_URL=mysql://test_user:test_pass@localhost:3306/test_db
FAKER_LOCALE=en_US
FAKER_SEED=12345

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR_AUTH=false
ENABLE_SOCIAL_LOGIN=true
ENABLE_API_RATE_LIMITING=true
ENABLE_MAINTENANCE_MODE=false

# Feature flag services
LAUNCHDARKLY_SDK_KEY=your_launchdarkly_key
OPTIMIZELY_SDK_KEY=your_optimizely_key

# =============================================================================
# CORS & SECURITY HEADERS
# =============================================================================
# CORS: https://github.com/expressjs/cors
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Content Security Policy: https://content-security-policy.com/
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self' 'unsafe-inline'
CSP_STYLE_SRC='self' 'unsafe-inline'
